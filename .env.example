NOWCAST_MODEL_CHECKPOINT=models/checkpoints/best_model.pt
FLASK_ENV=development
DEBUG=False

# Optional override. By default secrets are stored outside the repository:
# ~/.config/mrl_forecast/credentials.json (mode 0600)
# MRL_CREDENTIALS_FILE=/secure/path/mrl_credentials.json

# Prefer `python mrl.py sources --action configure --source <id>`.
# Environment variables override the credential file when explicitly set.
# KNMI_API_KEY=
# METEOGATE_API_KEY=
# METEOGATE_API_KEY_HEADER=
# METEOFRANCE_API_TOKEN=
# EARTHDATA_TOKEN=
